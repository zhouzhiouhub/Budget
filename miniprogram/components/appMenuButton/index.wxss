:host {
  display: block;
  flex-shrink: 0;
  width: 36rpx;
  height: 40rpx;
}

.menu-button {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  flex-shrink: 0;
  width: 36rpx;
  height: 40rpx;
  gap: 7rpx;
  border: none;
  border-radius: 0;
  padding: 0;
  margin: 0;
  background: transparent;
  box-shadow: none;
}

.menu-button::after {
  border: 0;
}

.menu-button-line {
  width: 30rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #24624d;
}
