page {
  min-height: 100%;
  background: #f5f7f3;
  color: #1f2933;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
}

view,
text,
button,
input {
  box-sizing: border-box;
}

button {
  background: initial;
  line-height: 1.2;
}

button::after {
  border: none;
}

.page-header.app-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 104rpx;
  margin-bottom: 32rpx;
  text-align: right;
}

.header-title-group {
  flex: 1;
  min-width: 0;
  text-align: right;
}
