page {
  min-height: 100%;
  background: #f5f7f3;
  color: #1f2933;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", sans-serif;
}

view,
text,
button,
input {
  box-sizing: border-box;
}

button {
  background: initial;
  line-height: 1.2;
}

button::after {
  border: none;
}
.page-header.app-header {
  display: flex;
  flex-direction: row;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  min-height: 104rpx;
  margin-bottom: 32rpx;
  text-align: right;
}

.header-title-group {
  flex: 1;
  min-width: 0;
  text-align: right;
}

.menu-button {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  flex-shrink: 0;
  width: 36rpx;
  height: 40rpx;
  gap: 7rpx;
  border: none;
  border-radius: 0;
  padding: 0;
  margin: 0;
  background: transparent;
  box-shadow: none;
}

.menu-button::after {
  border: 0;
}

.menu-button-line {
  width: 30rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #24624d;
}
