<view class="page-shell">
  <view class="page-header">
    <view class="eyebrow">{{periodLabel}}</view>
    <view class="page-title">{{pageTitle}}</view>
  </view>

  <view class="readonly-hint" wx:if="{{periodEditPolicy.is_readonly}}">{{periodEditPolicy.readonly_text}}</view>

  <view class="form-section">
      <view class="type-cell" wx:for="{{expenseTypes}}" wx:key="id">
        <button
          class="type-card {{selectedTypeId === item.id ? 'active' : ''}}"
          data-id="{{item.id}}"
          bindtap="onSelectType"
          hover-class="type-card-pressed"
          disabled="{{periodEditPolicy.is_readonly}}"
        >
          <view class="type-name">{{item.name}}</view>
          <view class="type-desc">{{item.description}}</view>
        </button>
      </view>
  </view>

  <view class="form-section" wx:if="{{selectedTypeId}}">
    <view class="section-title">消费金额</view>
    <view class="amount-field">
      <text class="currency">¥</text>
      <input
        class="amount-input"
        type="digit"
        value="{{amount_yuan}}"
        placeholder="0.00"
        bindinput="onAmountInput"
        disabled="{{periodEditPolicy.is_readonly}}"
      />
    </view>
  </view>

  <view class="form-section" wx:if="{{canWriteRemark}}">
    <view class="section-title">备注</view>
    <textarea
      class="remark-input"
      value="{{remark}}"
      maxlength="80"
      auto-height="{{false}}"
      placeholder="写点备注，例如：和客户午餐、打车去公司"
      bindinput="onRemarkInput"
      disabled="{{periodEditPolicy.is_readonly}}"
    />
    <view class="remark-counter">{{remark.length}} / 80</view>
  </view>

  <view class="hint-card" wx:if="{{!selectedTypeId && !periodEditPolicy.is_readonly}}">
    先选择消费类型，随后可填写金额和备注。
  </view>

  <view class="feedback error" wx:if="{{errorMessage}}">{{errorMessage}}</view>
  <view class="feedback success" wx:if="{{successMessage}}">{{successMessage}}</view>

  <button
    class="submit-button"
    loading="{{status === 'submitting'}}"
    disabled="{{status === 'submitting' || status === 'loading' || periodEditPolicy.is_readonly}}"
    bindtap="onSubmit"
  >
    {{submitButtonText}}
  </button>
</view>
