page {
  background: #f5f7f3;
}

.page-shell {
  min-height: 100vh;
  padding: 40rpx 32rpx 56rpx;
}

.page-header {
  margin-bottom: 32rpx;
}

.eyebrow {
  color: #617064;
  font-size: 24rpx;
  line-height: 32rpx;
}

.page-title {
  margin-top: 8rpx;
  color: #17221b;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 56rpx;
}

.form-section {
  margin-top: 28rpx;
}

.section-title {
  color: #17221b;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 40rpx;
  margin-bottom: 18rpx;
}

.type-grid {
  display: flex;
  flex-wrap: wrap;
  align-items: stretch;
  margin-right: -18rpx;
  margin-bottom: -18rpx;
}

.type-cell {
  flex: 0 0 33.333333%;
  width: 33.333333%;
  max-width: 33.333333%;
  min-width: 0;
  padding-right: 18rpx;
  padding-bottom: 18rpx;
  box-sizing: border-box;
}

.type-card {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: flex-start;
  width: 100%;
  min-width: 0;
  min-height: 128rpx;
  border: 1rpx solid rgba(31, 41, 51, 0.08);
  border-radius: 12rpx;
  padding: 16rpx 14rpx;
  margin: 0;
  background: #ffffff;
  text-align: left;
  box-sizing: border-box;
  box-shadow: 0 10rpx 28rpx rgba(41, 54, 46, 0.07);
}

.type-card.disabled {
  opacity: 0.58;
}

.type-card.active {
  border-color: #13795b;
  background: #eaf5ef;
}

.type-name {
  width: 100%;
  color: #17221b;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 34rpx;
  text-align: left;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.type-desc {
  display: block;
  width: 100%;
  margin-top: 6rpx;
  color: #617064;
  font-size: 20rpx;
  line-height: 28rpx;
  text-align: left;
  white-space: normal;
  word-break: break-all;
}

.amount-field,
.remark-input,
.hint-card,
.feedback {
  border: 1rpx solid rgba(31, 41, 51, 0.08);
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(41, 54, 46, 0.07);
}

.amount-field {
  display: flex;
  align-items: center;
  min-height: 108rpx;
  padding: 0 28rpx;
}

.currency {
  color: #13795b;
  font-size: 40rpx;
  font-weight: 700;
  margin-right: 16rpx;
}

.amount-input {
  flex: 1;
  color: #17221b;
  font-size: 42rpx;
  font-weight: 700;
}

.remark-input {
  width: 100%;
  min-height: 184rpx;
  padding: 24rpx;
  color: #17221b;
  font-size: 28rpx;
  line-height: 40rpx;
}

.remark-counter {
  margin-top: 10rpx;
  color: #7a867d;
  font-size: 24rpx;
  text-align: right;
}

.hint-card {
  margin-top: 32rpx;
  padding: 28rpx;
  color: #617064;
  font-size: 28rpx;
  line-height: 40rpx;
}

.feedback {
  margin-top: 24rpx;
  padding: 22rpx 26rpx;
  font-size: 26rpx;
  line-height: 36rpx;
}

.feedback.error {
  color: #be123c;
  background: #fff1f2;
}

.feedback.success {
  color: #13795b;
  background: #eaf5ef;
}

.submit-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 92rpx;
  margin-top: 36rpx;
  border-radius: 16rpx;
  background: #13795b;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 1;
}

.submit-button[disabled] {
  background: #9db5a9;
  color: #ffffff;
}
