page {
  background: #f5f7f3;
}

.page-shell {
  min-height: 100vh;
  padding: 40rpx 32rpx 56rpx;
}

.page-header {
  margin-bottom: 32rpx;
}

.eyebrow {
  color: #617064;
  font-size: 24rpx;
  line-height: 32rpx;
}

.page-title {
  margin-top: 8rpx;
  color: #17221b;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 56rpx;
}

.form-section {
  margin-top: 28rpx;
}

.section-title {
  color: #17221b;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 40rpx;
  margin-bottom: 18rpx;
}

.type-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.type-card {
  min-height: 144rpx;
  padding: 24rpx;
  border: 1rpx solid rgba(31, 41, 51, 0.08);
  border-radius: 16rpx;
  background: #ffffff;
  text-align: left;
  box-shadow: 0 10rpx 28rpx rgba(41, 54, 46, 0.07);
}

.type-card.active {
  border-color: #13795b;
  background: #eaf5ef;
}

.type-name {
  color: #17221b;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 40rpx;
}

.type-desc {
  margin-top: 10rpx;
  color: #617064;
  font-size: 24rpx;
  line-height: 34rpx;
}

.amount-field,
.remark-input,
.hint-card,
.feedback {
  border: 1rpx solid rgba(31, 41, 51, 0.08);
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(41, 54, 46, 0.07);
}

.amount-field {
  display: flex;
  align-items: center;
  min-height: 108rpx;
  padding: 0 28rpx;
}

.currency {
  color: #13795b;
  font-size: 40rpx;
  font-weight: 700;
  margin-right: 16rpx;
}

.amount-input {
  flex: 1;
  color: #17221b;
  font-size: 42rpx;
  font-weight: 700;
}

.remark-input {
  width: 100%;
  min-height: 184rpx;
  padding: 24rpx;
  color: #17221b;
  font-size: 28rpx;
  line-height: 40rpx;
}

.remark-counter {
  margin-top: 10rpx;
  color: #7a867d;
  font-size: 24rpx;
  text-align: right;
}

.hint-card {
  margin-top: 32rpx;
  padding: 28rpx;
  color: #617064;
  font-size: 28rpx;
  line-height: 40rpx;
}

.feedback {
  margin-top: 24rpx;
  padding: 22rpx 26rpx;
  font-size: 26rpx;
  line-height: 36rpx;
}

.feedback.error {
  color: #be123c;
  background: #fff1f2;
}

.feedback.success {
  color: #13795b;
  background: #eaf5ef;
}

.submit-button {
  height: 92rpx;
  margin-top: 36rpx;
  border-radius: 16rpx;
  background: #13795b;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 700;
}

.submit-button[disabled] {
  background: #9db5a9;
  color: #ffffff;
}