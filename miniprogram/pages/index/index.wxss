page {
  background: #f5f7f3;
}

.page-shell {
  min-height: 100vh;
  padding: 40rpx 32rpx 56rpx;
}

.app-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
  margin-bottom: 32rpx;
}

.header-title-group {
  flex: 1;
  min-width: 0;
}

.menu-button {
  display: flex;
  flex-direction: column;
  align-items: flex-start;
  justify-content: center;
  flex-shrink: 0;
  width: 36rpx;
  height: 40rpx;
  gap: 7rpx;
  border: none;
  border-radius: 0;
  padding: 0;
  margin: 0;
  background: transparent;
  box-shadow: none;
}

.menu-button::after,
.side-menu-close::after,
.side-menu-item::after {
  border: 0;
}

.menu-button-line {
  width: 30rpx;
  height: 4rpx;
  border-radius: 999rpx;
  background: #24624d;
}

.eyebrow {
  color: #617064;
  font-size: 24rpx;
  line-height: 32rpx;
}

.page-title {
  margin-top: 8rpx;
  color: #17221b;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 56rpx;
}

.scope-pill,
.status-badge {
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
  font-size: 24rpx;
  line-height: 32rpx;
}

.scope-pill {
  flex-shrink: 0;
  background: #e7eee9;
  color: #24624d;
}

.state-panel,
.summary-card,
.transaction-item {
  border: 1rpx solid rgba(31, 41, 51, 0.08);
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(41, 54, 46, 0.07);
}

.state-panel {
  padding: 48rpx 36rpx;
}

.state-panel.error {
  border-color: rgba(190, 18, 60, 0.2);
}

.state-title {
  color: #17221b;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 44rpx;
}

.state-text {
  margin-top: 12rpx;
  color: #617064;
  font-size: 28rpx;
  line-height: 40rpx;
}

.summary-card {
  padding: 32rpx;
}

.summary-head,
.summary-footer,
.section-row,
.transaction-item,
.quick-actions,
.budget-metrics {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.summary-label {
  color: #617064;
  font-size: 26rpx;
  line-height: 36rpx;
}

.summary-amount {
  margin-top: 8rpx;
  color: #17221b;
  font-size: 52rpx;
  font-weight: 700;
  line-height: 64rpx;
}

.budget-metrics {
  gap: 20rpx;
  margin-top: 28rpx;
}

.metric-item {
  flex: 1;
  min-width: 0;
  border-radius: 12rpx;
  background: #f3f7f1;
  padding: 20rpx;
}

.metric-label {
  color: #617064;
  font-size: 24rpx;
  line-height: 32rpx;
}

.metric-value {
  margin-top: 8rpx;
  color: #17221b;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 40rpx;
}

.summary-footer {
  margin-top: 14rpx;
  color: #617064;
  font-size: 24rpx;
  line-height: 32rpx;
}

.status-badge {
  background: #e7eee9;
  color: #13795b;
}

.summary-card.warning .status-badge {
  background: #fff3cf;
  color: #9a5b00;
}

.summary-card.over-budget .status-badge {
  background: #ffe4e6;
  color: #be123c;
}

.progress-track {
  height: 16rpx;
  margin-top: 22rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e8ece6;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #13795b;
}

.summary-card.warning .progress-fill {
  background: #d97706;
}

.summary-card.over-budget .progress-fill {
  background: #e11d48;
}

.readonly-note {
  margin-top: 18rpx;
  border-radius: 12rpx;
  padding: 16rpx 18rpx;
  background: #fff7ed;
  color: #9a5b00;
  font-size: 24rpx;
  line-height: 34rpx;
}

.quick-actions {
  gap: 20rpx;
  margin-top: 24rpx;
}

.primary-button {
  display: flex;
  align-items: center;
  justify-content: center;
  min-width: 0;
  height: 88rpx;
  border-radius: 14rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 1;
  flex: 1;
  background: #13795b;
  color: #ffffff;
}
.section-row {
  margin-top: 40rpx;
}

.section-title {
  color: #17221b;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.section-count {
  color: #617064;
  font-size: 24rpx;
  line-height: 34rpx;
}

.transaction-list {
  margin-top: 18rpx;
}

.transaction-item {
  min-height: 112rpx;
  padding: 22rpx 26rpx;
  margin-bottom: 16rpx;
}

.transaction-item.removing {
  opacity: 0.55;
}

.transaction-name {
  color: #17221b;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 38rpx;
}

.transaction-meta {
  margin-top: 6rpx;
  color: #69766d;
  font-size: 24rpx;
  line-height: 32rpx;
}

.transaction-amount {
  color: #be123c;
  font-size: 28rpx;
  font-weight: 700;
}

.side-menu-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 30;
  background: rgba(23, 34, 27, 0.38);
}

.side-menu-panel {
  position: fixed;
  left: 0;
  top: 0;
  bottom: 0;
  z-index: 31;
  width: 280rpx;
  max-width: 41vw;
  border-radius: 0 22rpx 22rpx 0;
  background: #ffffff;
  padding: 48rpx 20rpx;
  box-shadow: 18rpx 0 44rpx rgba(23, 34, 27, 0.16);
  overflow: hidden;
}

.side-menu-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
}

.side-menu-label {
  color: #617064;
  font-size: 24rpx;
  line-height: 32rpx;
}

.side-menu-title {
  margin-top: 4rpx;
  color: #17221b;
  font-size: 38rpx;
  font-weight: 700;
  line-height: 48rpx;
}

.side-menu-close {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 44rpx;
  height: 44rpx;
  min-width: 0;
  border: 0;
  border-radius: 50%;
  padding: 0;
  margin: 0;
  background: transparent;
  color: #24624d;
  font-size: 28rpx;
  line-height: 1;
}

.side-menu-list {
  margin-top: 28rpx;
}

.side-menu-item {
  display: flex;
  align-items: center;
  justify-content: flex-start;
  width: 100%;
  min-width: 0;
  height: 64rpx;
  border-radius: 10rpx;
  border: 0;
  padding: 0 14rpx;
  margin: 0 0 14rpx;
  background: #f5f7f3;
  color: #24624d;
  font-size: 24rpx;
  font-weight: 600;
  line-height: 1;
  text-align: left;
  overflow: hidden;
}

.side-menu-item.active {
  background: #13795b;
  color: #ffffff;
}

.side-menu-item.pending {
  background: #f7faf6;
  color: #6f7a72;
}
