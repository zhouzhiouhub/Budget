page {
  background: #f5f7f3;
}

.page-shell {
  min-height: 100vh;
  padding: 40rpx 32rpx 56rpx;
}

.app-header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  margin-bottom: 32rpx;
}

.eyebrow {
  color: #617064;
  font-size: 24rpx;
  line-height: 32rpx;
}

.page-title {
  margin-top: 8rpx;
  color: #17221b;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 56rpx;
}

.scope-pill,
.status-badge {
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
  font-size: 24rpx;
  line-height: 32rpx;
}

.scope-pill {
  background: #e7eee9;
  color: #24624d;
}

.state-panel,
.summary-card,
.transaction-item {
  border: 1rpx solid rgba(31, 41, 51, 0.08);
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(41, 54, 46, 0.07);
}

.state-panel {
  padding: 48rpx 36rpx;
}

.state-panel.error {
  border-color: rgba(190, 18, 60, 0.2);
}

.state-title {
  color: #17221b;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 44rpx;
}

.state-text {
  margin-top: 12rpx;
  color: #617064;
  font-size: 28rpx;
  line-height: 40rpx;
}

.summary-card {
  padding: 32rpx;
}

.summary-head,
.summary-footer,
.section-row,
.transaction-item,
.quick-actions,
.budget-metrics {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.summary-label {
  color: #617064;
  font-size: 26rpx;
  line-height: 36rpx;
}

.summary-amount {
  margin-top: 8rpx;
  color: #17221b;
  font-size: 52rpx;
  font-weight: 700;
  line-height: 64rpx;
}

.budget-metrics {
  gap: 20rpx;
  margin-top: 28rpx;
}

.metric-item {
  flex: 1;
  min-width: 0;
  border-radius: 12rpx;
  background: #f3f7f1;
  padding: 20rpx;
}

.metric-label {
  color: #617064;
  font-size: 24rpx;
  line-height: 32rpx;
}

.metric-value {
  margin-top: 8rpx;
  color: #17221b;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 40rpx;
}

.summary-footer {
  margin-top: 14rpx;
  color: #617064;
  font-size: 24rpx;
  line-height: 32rpx;
}

.status-badge {
  background: #e7eee9;
  color: #13795b;
}

.summary-card.warning .status-badge {
  background: #fff3cf;
  color: #9a5b00;
}

.summary-card.over-budget .status-badge {
  background: #ffe4e6;
  color: #be123c;
}

.progress-track {
  height: 16rpx;
  margin-top: 22rpx;
  overflow: hidden;
  border-radius: 999rpx;
  background: #e8ece6;
}

.progress-fill {
  height: 100%;
  border-radius: 999rpx;
  background: #13795b;
}

.summary-card.warning .progress-fill {
  background: #d97706;
}

.summary-card.over-budget .progress-fill {
  background: #e11d48;
}

.quick-actions {
  gap: 20rpx;
  margin-top: 24rpx;
}

.primary-button,
.secondary-button {
  min-width: 0;
  height: 88rpx;
  border-radius: 14rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.primary-button {
  flex: 1;
  background: #13795b;
  color: #ffffff;
}

.secondary-button {
  flex: 1;
  border: 1rpx solid #b8c7bc;
  background: #ffffff;
  color: #24624d;
}

.section-row {
  margin-top: 40rpx;
}

.section-title {
  color: #17221b;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.section-count {
  color: #617064;
  font-size: 24rpx;
}

.transaction-list {
  margin-top: 18rpx;
}

.transaction-item {
  min-height: 112rpx;
  padding: 22rpx 26rpx;
  margin-bottom: 16rpx;
}

.transaction-name {
  color: #17221b;
  font-size: 28rpx;
  font-weight: 600;
  line-height: 38rpx;
}

.transaction-meta {
  margin-top: 6rpx;
  color: #69766d;
  font-size: 24rpx;
  line-height: 32rpx;
}

.transaction-amount {
  color: #be123c;
  font-size: 28rpx;
  font-weight: 700;
}