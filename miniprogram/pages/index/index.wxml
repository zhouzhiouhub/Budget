<view class="page-shell">
  <view class="app-header">
    <button class="menu-button" aria-label="打开菜单" bindtap="onOpenSideMenu">
      <view class="menu-button-line"></view>
      <view class="menu-button-line"></view>
      <view class="menu-button-line"></view>
    </button>
    <view class="header-title-group">
      <view class="page-title">预算管理</view>
      <view class="eyebrow">{{summary.period_label}}</view>
    </view>
    <view class="scope-pill">{{summary.scope_label}}</view>
  </view>

  <block wx:if="{{status === 'loading'}}">
    <view class="state-panel">
      <view class="state-title">加载中</view>
      <view class="state-text">正在整理本月总预算</view>
    </view>
  </block>

  <block wx:elif="{{status === 'error'}}">
    <view class="state-panel error">
      <view class="state-title">加载失败</view>
      <view class="state-text">{{errorMessage}}</view>
      <button class="primary-button" bindtap="refreshDashboard">重试</button>
    </view>
  </block>

  <block wx:elif="{{status === 'empty'}}">
    <view class="state-panel">
      <view class="state-title">{{summary.period_edit_policy.is_future_period ? "月份未到" : "暂无预算"}}</view>
      <view class="state-text">{{summary.period_edit_policy.is_future_period ? "当前还没有记录" : "本月还没有设置总预算，可在我的页面完成设置。"}}</view>
    </view>
  </block>

  <block wx:else>
    <view class="summary-card {{summary.statusClass}}">
      <view class="summary-head">
        <view>
          <view class="summary-label">{{summary.remainingTitle}}</view>
          <view class="summary-amount">{{summary.remainingDisplay}}</view>
        </view>
        <view class="status-badge">{{summary.statusText}}</view>
      </view>

      <view class="budget-metrics">
        <view class="metric-item">
          <view class="metric-label">总预算</view>
          <view class="metric-value">{{summary.totalDisplay}}</view>
        </view>
        <view class="metric-item">
          <view class="metric-label">已使用</view>
          <view class="metric-value">{{summary.usedDisplay}}</view>
        </view>
      </view>

      <view class="progress-track">
        <view class="progress-fill" style="width: {{summary.progressPercent}}%;"></view>
      </view>
      <view class="summary-footer">
        <text>{{summary.usedRateText}}</text>
        <text>{{summary.period_label}}</text>
      </view>
    </view>

    <view class="readonly-note" wx:if="{{periodEditPolicy.is_readonly}}">{{periodEditPolicy.readonly_text}}</view>

    <view class="quick-actions">
      <button class="primary-button" bindtap="onAddExpense">记一笔支出</button>
    </view>

    <view class="section-row transaction-title">
      <view class="section-title">最近花费</view>
      <view class="section-count">最近 5 笔</view>
    </view>

    <view class="transaction-list">
      <view class="transaction-item {{deletingRecordId === item.id ? 'removing' : ''}}" wx:for="{{transactions}}" wx:key="id" data-id="{{item.id}}" bindlongpress="onLongPressTransaction">
        <view>
          <view class="transaction-name">{{item.title}}</view>
          <view class="transaction-meta">{{item.metaText}}</view>
        </view>
        <view class="transaction-amount">{{item.amountLabel}}</view>
      </view>
    </view>
  </block>

  <view class="side-menu-mask" wx:if="{{showSideMenu}}" bindtap="onCloseSideMenu"></view>
  <view class="side-menu-panel" wx:if="{{showSideMenu}}">
    <view class="side-menu-header">
      <view>
        <view class="side-menu-title">菜单</view>
      </view>
      <button class="side-menu-close" aria-label="关闭菜单" bindtap="onCloseSideMenu">×</button>
    </view>
    <view class="side-menu-list">
      <button class="side-menu-item active" bindtap="onCloseSideMenu">首页</button>
      <button class="side-menu-item" bindtap="onViewRecords">消费</button>
      <button class="side-menu-item" bindtap="onViewAnalytics">分析</button>
      <button class="side-menu-item" bindtap="onViewProfile">我的</button>
    </view>
  </view>
</view>
