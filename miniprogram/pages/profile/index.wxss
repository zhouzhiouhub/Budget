page {
  background: #f5f7f3;
}

.page-shell {
  min-height: 100vh;
  padding: 40rpx 32rpx 56rpx;
}

.profile-header {
  display: flex;
  align-items: center;
  gap: 22rpx;
  margin-bottom: 28rpx;
}

.avatar-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  width: 92rpx;
  height: 92rpx;
  border-radius: 50%;
  background: #13795b;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
}

.profile-copy {
  min-width: 0;
}

.eyebrow,
.profile-desc,
.section-desc,
.info-row {
  color: #617064;
  font-size: 24rpx;
  line-height: 32rpx;
}

.page-title {
  margin-top: 4rpx;
  color: #17221b;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 56rpx;
}

.profile-desc {
  margin-top: 4rpx;
}

.state-panel,
.form-card,
.info-card {
  border: 1rpx solid rgba(31, 41, 51, 0.08);
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(41, 54, 46, 0.07);
}

.state-panel {
  padding: 44rpx 32rpx;
}

.state-panel.error {
  border-color: rgba(190, 18, 60, 0.2);
}

.state-title {
  color: #17221b;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.state-text {
  margin-top: 10rpx;
  color: #617064;
  font-size: 26rpx;
  line-height: 36rpx;
}

.retry-button,
.save-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 82rpx;
  border: 0;
  border-radius: 12rpx;
  background: #13795b;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
}

.retry-button {
  width: 180rpx;
  margin: 28rpx 0 0;
}

.retry-button::after,
.save-button::after {
  border: 0;
}

.form-card,
.info-card {
  padding: 28rpx;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  color: #17221b;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.info-card {
  margin-top: 24rpx;
}

.section-desc {
  margin-top: 8rpx;
}

.budget-input-row {
  display: flex;
  align-items: center;
  min-height: 96rpx;
  margin-top: 24rpx;
  padding: 0 22rpx;
  border: 1rpx solid #c9d7ce;
  border-radius: 14rpx;
  background: #f8faf7;
}

.currency {
  flex-shrink: 0;
  margin-right: 14rpx;
  color: #13795b;
  font-size: 38rpx;
  font-weight: 700;
}

.budget-input {
  flex: 1;
  min-width: 0;
  color: #17221b;
  font-size: 38rpx;
  font-weight: 700;
}

.editor-error {
  margin-top: 14rpx;
  color: #be123c;
  font-size: 24rpx;
  line-height: 34rpx;
}

.save-button {
  width: 100%;
  margin-top: 24rpx;
}

.info-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.info-value {
  color: #17221b;
  font-weight: 600;
}
