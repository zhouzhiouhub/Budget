page {
  background: #f5f7f3;
}

.page-shell {
  min-height: 100vh;
  padding: 176rpx 32rpx 56rpx;
}

.profile-header {
  display: flex;
  align-items: center;
  gap: 22rpx;
  margin-bottom: 32rpx;
  border: 1rpx solid rgba(31, 41, 51, 0.08);
  border-radius: 16rpx;
  padding: 28rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(41, 54, 46, 0.07);
}

.avatar-picker {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 92rpx;
  width: 92rpx;
  min-width: 92rpx;
  max-width: 92rpx;
  height: 92rpx;
  min-height: 92rpx;
  max-height: 92rpx;
  box-sizing: border-box;
  border: 0;
  border-radius: 999rpx;
  padding: 0;
  margin: 0;
  background: transparent;
  line-height: 1;
  overflow: hidden;
}

.avatar-picker::after,
.edit-icon-button::after,
.save-button::after,
.retry-button::after,
.modal-button::after {
  border: 0;
}

.avatar-image {
  display: block;
  width: 92rpx;
  height: 92rpx;
  border-radius: 999rpx;
  background: #e7eee9;
}

.avatar-mark {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 92rpx;
  width: 92rpx;
  min-width: 92rpx;
  max-width: 92rpx;
  height: 92rpx;
  min-height: 92rpx;
  max-height: 92rpx;
  box-sizing: border-box;
  border-radius: 999rpx;
  background: #13795b;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 700;
}

.profile-copy {
  flex: 1;
  min-width: 0;
  text-align: right;
}

.eyebrow,
.profile-desc,
.section-desc,
.info-row {
  color: #617064;
  font-size: 24rpx;
  line-height: 32rpx;
}

.title-row {
  display: flex;
  align-items: center;
  justify-content: flex-end;
  gap: 10rpx;
  width: 100%;
  max-width: 100%;
  margin-top: 0;
}

.page-title {
  flex: 0 1 auto;
  min-width: 0;
  max-width: 360rpx;
  color: #17221b;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 56rpx;
  text-align: right;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.edit-icon-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 48rpx;
  width: 48rpx;
  height: 48rpx;
  min-width: 0;
  border: 0;
  border-radius: 999rpx;
  padding: 0;
  margin: 0;
  background: #e7eee9;
  color: #24624d;
  font-size: 28rpx;
  line-height: 1;
}

.profile-desc {
  margin-top: 4rpx;
}

.state-panel,
.form-card,
.info-card,
.nickname-editor {
  border: 1rpx solid rgba(31, 41, 51, 0.08);
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(41, 54, 46, 0.07);
}

.state-panel {
  padding: 44rpx 32rpx;
}

.state-panel.error {
  border-color: rgba(190, 18, 60, 0.2);
}

.state-title {
  color: #17221b;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.state-text {
  margin-top: 10rpx;
  color: #617064;
  font-size: 26rpx;
  line-height: 36rpx;
}

.retry-button,
.save-button {
  display: flex;
  align-items: center;
  justify-content: center;
  height: 82rpx;
  border: 0;
  border-radius: 12rpx;
  background: #13795b;
  color: #ffffff;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
}

.retry-button {
  width: 180rpx;
  margin: 28rpx 0 0;
}

.form-card,
.info-card {
  padding: 32rpx;
}

.info-card {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  margin-top: 24rpx;
}

.info-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  color: #17221b;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.section-desc {
  margin-top: 8rpx;
}

.budget-setting-row {
  display: flex;
  align-items: stretch;
  gap: 16rpx;
  margin-top: 24rpx;
}

.budget-month-segment,
.budget-amount-segment {
  min-height: 112rpx;
  box-sizing: border-box;
  border: 1rpx solid #c9d7ce;
  border-radius: 14rpx;
  padding: 16rpx 18rpx;
  background: #f8faf7;
}

.budget-month-segment {
  flex: 0 0 190rpx;
  width: 190rpx;
}

.budget-amount-segment {
  flex: 1;
  min-width: 0;
}

.segment-label {
  color: #617064;
  font-size: 22rpx;
  line-height: 30rpx;
}

.segment-value {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  margin-top: 12rpx;
  color: #17221b;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 40rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.picker-arrow {
  flex-shrink: 0;
  color: #617064;
  font-size: 22rpx;
  line-height: 1;
}

.budget-amount-input-row {
  display: flex;
  align-items: center;
  min-height: 48rpx;
  margin-top: 6rpx;
}

.currency {
  flex-shrink: 0;
  margin-right: 14rpx;
  color: #13795b;
  font-size: 38rpx;
  font-weight: 700;
}

.budget-input,
.nickname-input {
  flex: 1;
  min-width: 0;
  color: #17221b;
  font-size: 38rpx;
  font-weight: 700;
}

.editor-error {
  margin-top: 14rpx;
  color: #be123c;
  font-size: 24rpx;
  line-height: 34rpx;
}

.save-button {
  width: 100%;
  margin-top: 24rpx;
}

.info-value {
  color: #17221b;
  font-weight: 600;
}

.modal-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 20;
  display: flex;
  align-items: flex-end;
  justify-content: center;
  padding: 32rpx;
  background: rgba(23, 34, 27, 0.42);
}

.nickname-editor {
  width: 100%;
  padding: 32rpx;
  border-radius: 20rpx;
}

.modal-title {
  color: #17221b;
  font-size: 34rpx;
  font-weight: 700;
  line-height: 44rpx;
}

.nickname-input {
  box-sizing: border-box;
  width: 100%;
  height: 96rpx;
  margin-top: 24rpx;
  border: 1rpx solid #c9d7ce;
  border-radius: 14rpx;
  padding: 0 22rpx;
  background: #f8faf7;
  font-size: 34rpx;
}

.modal-actions {
  display: flex;
  align-items: center;
  gap: 18rpx;
  margin-top: 30rpx;
}

.modal-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 1;
  height: 86rpx;
  border: 0;
  border-radius: 14rpx;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 1;
}

.modal-button.ghost {
  border: 1rpx solid #c9d7ce;
  background: #ffffff;
  color: #24624d;
}

.modal-button.primary {
  background: #13795b;
  color: #ffffff;
}

.readonly-hint {
  margin-top: 16rpx;
  border-radius: 12rpx;
  padding: 16rpx 18rpx;
  background: #fff7ed;
  color: #9a5b00;
  font-size: 24rpx;
  line-height: 34rpx;
}

.budget-input[disabled] {
  color: #7a867d;
}
