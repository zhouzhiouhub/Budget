<view class="page-shell">
  <view class="profile-header">
    <button
      class="avatar-picker header-avatar"
      open-type="chooseAvatar"
      bindchooseavatar="onChooseAvatar"
      loading="{{avatarEditorStatus === 'saving'}}"
      disabled="{{avatarEditorStatus === 'saving'}}"
      aria-label="更换头像"
    >
      <image wx:if="{{userProfile.avatar_url}}" class="avatar-image" src="{{userProfile.avatar_url}}" mode="aspectFill"></image>
      <view wx:else class="avatar-mark">{{userProfile.avatar_text}}</view>
    </button>
    <view class="profile-copy">
      <view class="eyebrow">BudgetFlow</view>
      <view class="title-row">
        <view class="page-title">{{userProfile.nickname}}</view>
        <button class="edit-icon-button" aria-label="编辑昵称" bindtap="onOpenNicknameEditor">✎</button>
      </view>
      <view class="profile-desc">个人预算与偏好设置</view>
    </view>
  </view>

  <view class="state-panel" wx:if="{{status === 'loading'}}">
    <view class="state-title">加载中</view>
    <view class="state-text">正在读取个人资料和预算信息</view>
  </view>

  <view class="state-panel error" wx:elif="{{status === 'error'}}">
    <view class="state-title">加载失败</view>
    <view class="state-text">{{errorMessage}}</view>
    <button class="retry-button" bindtap="refreshProfile">重试</button>
  </view>

  <block wx:else>
    <view class="form-card">
      <view class="section-title">预算设置</view>
      <view class="section-desc">设置本月总预算，后续消费会从这里扣减。</view>
      <view class="budget-setting-row">
        <view class="budget-month-segment">
          <view class="segment-label">月份</view>
          <view class="segment-value">{{summary.period_label}}</view>
        </view>
        <view class="budget-amount-segment">
          <view class="segment-label">预算金额</view>
          <view class="budget-amount-input-row">
            <text class="currency">¥</text>
            <input
              class="budget-input"
              type="digit"
              value="{{budgetAmountInput}}"
              placeholder="0.00"
              bindinput="onBudgetAmountInput"
            />
          </view>
        </view>
      </view>
      <view class="editor-error" wx:if="{{budgetEditorError}}">{{budgetEditorError}}</view>
      <button
        class="save-button"
        loading="{{budgetEditorStatus === 'saving'}}"
        disabled="{{budgetEditorStatus === 'saving'}}"
        bindtap="onSaveBudgetAmount"
      >保存预算</button>
    </view>
    <view class="info-card">
      <view class="info-row">
        <text>预算范围</text>
        <text class="info-value">{{summary.scope_label}}</text>
      </view>
      <view class="info-row">
        <text>金额单位</text>
        <text class="info-value">元</text>
      </view>
      <view class="info-row">
        <text>数据存储</text>
        <text class="info-value">本机小程序缓存</text>
      </view>
    </view>
  </block>

  <view class="modal-mask" wx:if="{{showNicknameEditor}}">
    <view class="nickname-editor">
      <view class="modal-title">修改昵称</view>
      <input
        class="nickname-input"
        type="nickname"
        value="{{nicknameEditorInput}}"
        placeholder="请输入昵称"
        focus="{{showNicknameEditor}}"
        bindinput="onNicknameInput"
      />
      <view class="editor-error" wx:if="{{nicknameEditorError}}">{{nicknameEditorError}}</view>
      <view class="modal-actions">
        <button class="modal-button ghost" bindtap="onCancelNicknameEdit">取消</button>
        <button
          class="modal-button primary"
          loading="{{nicknameEditorStatus === 'saving'}}"
          disabled="{{nicknameEditorStatus === 'saving'}}"
          bindtap="onSaveNickname"
        >保存</button>
      </view>
    </view>
  </view>
</view>
