page {
  background: #f5f7f3;
}

.page-shell {
  min-height: 100vh;
  padding: 40rpx 32rpx 56rpx;
}

.page-header {
  margin-bottom: 28rpx;
}

.eyebrow {
  color: #617064;
  font-size: 24rpx;
  line-height: 32rpx;
}

.page-title {
  margin-top: 8rpx;
  color: #17221b;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 56rpx;
}

.filter-scroll {
  width: 100%;
  white-space: nowrap;
  margin-bottom: 28rpx;
}

.filter-row {
  display: flex;
  gap: 16rpx;
}

.filter-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  height: 68rpx;
  border: 1rpx solid #c9d7ce;
  border-radius: 999rpx;
  padding: 0 28rpx;
  background: #ffffff;
  color: #24624d;
  font-size: 26rpx;
  line-height: 1;
}

.filter-chip.active {
  border-color: #13795b;
  background: #13795b;
  color: #ffffff;
}

.state-panel,
.record-item {
  border: 1rpx solid rgba(31, 41, 51, 0.08);
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(41, 54, 46, 0.07);
}

.state-panel {
  padding: 44rpx 32rpx;
}

.state-panel.error {
  border-color: rgba(190, 18, 60, 0.2);
}

.state-title {
  color: #17221b;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.state-text {
  margin-top: 10rpx;
  color: #617064;
  font-size: 26rpx;
  line-height: 36rpx;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-item {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 120rpx;
  padding: 24rpx 26rpx;
}

.record-main {
  min-width: 0;
  padding-right: 20rpx;
}

.record-title {
  color: #17221b;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 40rpx;
}

.record-meta,
.record-remark {
  margin-top: 6rpx;
  color: #69766d;
  font-size: 24rpx;
  line-height: 32rpx;
}

.record-remark {
  color: #405148;
}

.record-amount {
  flex-shrink: 0;
  color: #be123c;
  font-size: 28rpx;
  font-weight: 700;
}