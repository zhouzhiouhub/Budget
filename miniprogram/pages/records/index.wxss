page {
  background: #f5f7f3;
}

.page-shell {
  min-height: 100vh;
  padding: 40rpx 32rpx 180rpx;
  padding-bottom: calc(180rpx + env(safe-area-inset-bottom));
}

.page-header {
  margin-bottom: 28rpx;
}

.eyebrow {
  color: #617064;
  font-size: 24rpx;
  line-height: 32rpx;
}

.page-title {
  margin-top: 8rpx;
  color: #17221b;
  font-size: 44rpx;
  font-weight: 700;
  line-height: 56rpx;
}

.filter-panel {
  width: 100%;
  margin-bottom: 30rpx;
}

.filter-row {
  display: flex;
  flex-wrap: wrap;
  align-items: flex-start;
  justify-content: flex-start;
  margin: 0 -12rpx -24rpx;
}

.filter-cell {
  flex: 0 0 33.333333%;
  max-width: 33.333333%;
  padding: 0 12rpx 24rpx;
  box-sizing: border-box;
}

.filter-chip {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 72rpx;
  border: 1rpx solid #d7e4dc;
  border-radius: 12rpx;
  padding: 0 8rpx;
  background: #ffffff;
  color: #315f4d;
  font-size: 26rpx;
  font-weight: 700;
  line-height: 1;
  text-align: center;
  box-sizing: border-box;
  box-shadow: 0 4rpx 10rpx rgba(41, 54, 46, 0.04);
}

.filter-chip-pressed {
  background: #edf6f1;
}

.filter-chip.active {
  border-color: #13795b;
  background: #13795b;
  color: #ffffff;
  box-shadow: 0 8rpx 18rpx rgba(19, 121, 91, 0.18);
}

.state-panel,
.record-item,
.record-total {
  border: 1rpx solid rgba(31, 41, 51, 0.08);
  border-radius: 16rpx;
  background: #ffffff;
  box-shadow: 0 10rpx 28rpx rgba(41, 54, 46, 0.07);
}

.state-panel {
  padding: 44rpx 32rpx;
}

.state-panel.error {
  border-color: rgba(190, 18, 60, 0.2);
}

.state-title {
  color: #17221b;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 42rpx;
}

.state-text {
  margin-top: 10rpx;
  color: #617064;
  font-size: 26rpx;
  line-height: 36rpx;
}

.record-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.record-item,
.record-total {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 120rpx;
  padding: 24rpx 26rpx;
}

.record-main {
  min-width: 0;
  padding-right: 20rpx;
}

.record-title {
  color: #17221b;
  font-size: 30rpx;
  font-weight: 700;
  line-height: 40rpx;
}

.record-meta,
.record-remark {
  margin-top: 6rpx;
  color: #69766d;
  font-size: 24rpx;
  line-height: 32rpx;
}

.record-remark {
  color: #405148;
}

.record-amount {
  flex-shrink: 0;
  color: #be123c;
  font-size: 28rpx;
  font-weight: 700;
}
.record-total {
  position: fixed;
  left: 32rpx;
  right: 32rpx;
  bottom: 24rpx;
  bottom: calc(24rpx + env(safe-area-inset-bottom));
  z-index: 10;
  min-height: 96rpx;
  box-shadow: 0 16rpx 40rpx rgba(41, 54, 46, 0.14);
}

.record-total-label {
  color: #405148;
  font-size: 28rpx;
  font-weight: 700;
  line-height: 38rpx;
}

.record-total-value {
  flex-shrink: 0;
  color: #be123c;
  font-size: 32rpx;
  font-weight: 700;
  line-height: 40rpx;
}
