<view class="page-shell">
  <view class="page-header app-header">
    <button class="menu-button" aria-label="打开菜单" bindtap="onOpenSideMenu">
    <view class="menu-button-line"></view>
    <view class="menu-button-line"></view>
    <view class="menu-button-line"></view>
    </button>
    <view class="header-title-group">
    <view class="eyebrow">{{periodLabel}}</view>
    <view class="page-title">消费</view>
  </view>
</view>

  <view class="readonly-note" wx:if="{{periodEditPolicy.is_readonly && !periodEditPolicy.is_future_period}}">{{periodEditPolicy.readonly_text}}</view>

  <view class="filter-panel">
    <view class="filter-row">
      <view class="filter-cell" wx:for="{{filters}}" wx:key="id">
        <view
          class="filter-chip {{selectedTypeId === item.id ? 'active' : ''}}"
          data-id="{{item.id}}"
          bindtap="onSelectType"
          hover-class="filter-chip-pressed"
        >{{item.name}}</view>
      </view>
    </view>
  </view>

  <view class="state-panel" wx:if="{{status === 'loading'}}">
    <view class="state-title">加载中</view>
    <view class="state-text">正在读取消费</view>
  </view>

  <view class="state-panel error" wx:elif="{{status === 'error'}}">
    <view class="state-title">加载失败</view>
    <view class="state-text">{{errorMessage}}</view>
  </view>

  <view class="state-panel" wx:elif="{{status === 'empty'}}">
    <view class="state-title">{{periodEditPolicy.is_future_period ? "月份未到" : "暂无记录"}}</view>
    <view class="state-text">{{periodEditPolicy.is_future_period ? "当前还没有记录" : "当前类型还没有消费"}}</view>
  </view>

  <view class="record-list" wx:else>
    <view class="record-item {{deletingRecordId === item.id ? 'removing' : ''}}" wx:for="{{records}}" wx:key="id" data-id="{{item.id}}" bindlongpress="onLongPressRecord">
      <view class="record-main">
        <view class="record-title">{{item.title}}</view>
        <view class="record-meta">{{item.expense_type_name}} · {{item.occurred_at_display}}</view>
        <view class="record-remark" wx:if="{{item.remark}}">{{item.remark}}</view>
      </view>
      <view class="record-amount">{{item.amountLabel}}</view>
    </view>
    <view class="record-total">
      <view class="record-total-label">合计支出</view>
      <view class="record-total-value">-{{totalAmountDisplay}}</view>
    </view>
  </view>
  <app-side-menu visible="{{showSideMenu}}" active="records" bind:close="onCloseSideMenu"></app-side-menu>
</view>
